{
    "version": 2,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.8.0" }
    },
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/index.php" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "APP_STORAGE": "/tmp"
    }
}